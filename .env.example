# ── Wallet / Auth ─────────────────────────────────────────────────
WALLET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
POLY_FUNDER_ADDRESS=0xYOUR_FUNDER_ADDRESS_HERE   # Polymarket Settings → Profile
POLY_API_KEY=your_api_key
POLY_API_SECRET=your_api_secret
POLY_API_PASSPHRASE=your_api_passphrase
POLYGON_RPC=https://polygon-rpc.com

# ── Capital ────────────────────────────────────────────────────────
INITIAL_BANKROLL_USDC=1000.0

# ── Mode ───────────────────────────────────────────────────────────
DRY_RUN=true   # Set to false for live trading

# ── Strategy: certainty band ───────────────────────────────────────
# Enter markets where YES or NO price is between these values
CERT_LO=0.90
CERT_HI=0.95

# How much above market price we assume our true probability is
# Used for Kelly sizing — generates positive expected value
CONFIDENCE_PREMIUM=0.025

# ── Kelly / Sizing ─────────────────────────────────────────────────
KELLY_FRACTION=0.25
MAX_PCT_PER_TRADE=0.05       # Max 5% of bankroll per position
MIN_PCT_PER_TRADE=0.005      # Min 0.5% of bankroll per position
MIN_ORDER_USDC=2.0           # Don't place orders below $2

# ── Risk ───────────────────────────────────────────────────────────
DAILY_DRAWDOWN_LIMIT=0.20    # Pause if down 20% on the day
DRAWDOWN_PAUSE_HOURS=4.0
MAX_OPEN_POSITIONS=20        # Max simultaneous open bets

# ── Scanning ───────────────────────────────────────────────────────
SCAN_INTERVAL_SEC=60         # Scan every 60 seconds
GAMMA_PAGE_SIZE=100
MIN_LIQUIDITY_USDC=500       # Skip illiquid markets
MAX_SPREAD=0.03              # Skip if bid-ask spread > 3%
MIN_HOURS_TO_CLOSE=1.0       # Skip markets closing in < 1h
MAX_DAYS_TO_CLOSE=30.0       # Skip markets > 30 days out

# ── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
